    "eslint": "^10.2.1",
    "prettier": "^3.8.3",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.59.0"
  },
  "dependencies": {
    "playwright": "^1.59.1"
  }
