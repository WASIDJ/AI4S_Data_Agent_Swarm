# Agent Swarm 环境变量配置
# 复制此文件为 .env 并修改配置

# 服务器端口
PORT=3456

# 服务监听地址；Docker 部署时建议使用 0.0.0.0
HOST=127.0.0.1

# 系统最大并发任务数
MAX_CONCURRENT_TASKS=10

# WebSocket 最大连接数
MAX_WS_CLIENTS=10

# 工具审批超时时间（毫秒），超时自动拒绝
TOOL_APPROVAL_TIMEOUT_MS=300000

# 用户消息等待超时（毫秒）
USER_MESSAGE_TIMEOUT_MS=1800000

# Windows 环境必需：Git Bash 路径（SDK 调用 Claude Code 子进程时需要）
# macOS/Linux 可忽略此项
CLAUDE_CODE_GIT_BASH_PATH=D:\Git\bin\bash.exe

# 可选：Copilot / Agent API 配置
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_BASE_URL=
COPILOT_MODEL=glm-5

# 可选：MinerU Open API token（PDF 解析任务）
MINERU_TOKEN=
